generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id Int @id @default(autoincrement())
  name String
  createdAt DateTime @default(now()) @map("created_at")
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  menuItemId Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  authorId Int @map("user_id")
  @@map("orders")
}

model User {
 id Int @id @default(autoincrement())
 email String @unique
 password String
 role Role @default(USER)
 orders Order[] 
 reviews Review[]
 @@map("users")
}

model Review {
  id Int @id @default(autoincrement())
  rating Int
  comment String
  createdAt DateTime @default(now()) @map("created_at")
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId Int @map("user_id") 
  menuItemId Int @map("menu_item_id")
  @@map("reviews")
}

model Menu{ 
  menuId Int @id @default(autoincrement()) 
  name String 
  description String 
  price Float 
  @@map("menu")
}

enum Role {
  USER
  ADMIN
} 
 
// Key Distinctions for Roles are provided below  
// 1. Admin: Make changes to Menu Items (Key Distinction solely for Administrators), Make Changes to Coffee Orders
// 2. User: Create Reviews, Orders, Sign-Up as well. 