generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     Role     @default(USER)

  orders  Order[]
  reviews Review[]
  menus   Menu[]

  @@map("users")
}

model Menu {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String
  price       Float

  // Nullable so seed/migrate doesn't fail if you don't supply it,
  // but still gives authorizeOwnership a column to check.
  owner   User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId  Int?  @map("user_id")

  orders  Order[]
  reviews Review[]

  @@map("menu")
}

model Order {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId Int  @map("user_id")

  menuItem Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuId   Int  @map("menu_id")

  @@map("orders")
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String
  createdAt DateTime @default(now()) @map("created_at")

  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId Int  @map("user_id")

  menuItem   Menu @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId Int  @map("menu_item_id")

  @@map("reviews")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

// Role notes:
//   ADMIN — manages menu items and any order/review.
//   USER  — creates orders and reviews; manages only their own.
